
# Commands:
# pallet "./filename" "name"
# place "name" {position} {rotation}
# varFloat "name" {value}
#   name should be alpha_numreic
#   no whitespace, no digit at the start



# Rotation for Ambient and Point are not neede or used
# Position for Ambient and Solar are only used for the Indicator

# some different Versions
# LightDirection: changes that the Last 3 Are
#   LightDirectionD: Direction (gets normalized)
#   LightDirectionR: Rotation
# LightSpot: changes that the Last 3 Are
#   LightSpotD: Direction (gets normalized)
#   LightSpotT: Target (gets normalized)
#   LightSpotR: Rotation

#LightAmbient   Intensity ( R G B )             Indicator ( X Y Z ) ( Z0 X1 Y2 )
#LightDirection Intensity ( R G B ) ( X Y Z )   Indicator ( X Y Z )
#LightPoint     Intensity ( R G B ) ( X Y Z )   Indicator ( Z0 X1 Y2 )
#LightSpot      Intensity ( R G B ) ( X Y Z ) ( X Y Z )

#LightAmbient      1.0   1.0 1.0 1.0     0.0 40.0   0.0   0.0 0.0 0.0

LightAmbient      0.1   1.0 1.0 1.0     0.0 40.0   0.0   0.0 0.0 0.0
LightDirectionD   0.8   1.0 1.0 1.0    +1.0 -3.0  +2.0   0.0 45.0 0.0
LightSpotT        1.0   1.0 0.0 0.0   +22.0 30.0 -22.0   0.0 0.0 0.0   0.80 0.95
LightSpotT        1.0   0.0 1.0 0.0     0.0 30.0 +22.0   0.0 0.0 0.0   0.80 0.95
LightSpotT        1.0   0.0 0.0 1.0   -22.0 30.0 -22.0   0.0 0.0 0.0   0.80 0.95



pallet Stage.polyhedra                       stage
pallet Truss/Square40cm_Len200cm.polyhedra   truss
pallet Truss/Cube40cm.polyhedra              truss_cube
pallet Chair.polyhedra                       chair

#pallet LightBulb.polyhedra                   light_bulb
#place light_bulb   0 64 0   00 00 90



place   stage   0 0 0   0 0 0



# truss_long = 20.0
# truss_wide = 4.5
#
# w0 = (truss_long * 1.0)
# w1 = (truss_long * 1.5) + (truss_wide * 0.5)
#
# h0 = (truss_long * 0.5)
# h1 = (truss_long * 1.5)
# h2 = (truss_long * 2.0) + (truss_wide * 0.5)
#
# d0 = (truss_long * 0.5)
# d1 = (truss_long * 1.0) + (truss_wide * 0.5)

# do Math, when to do math ?
# math has to be in ()
# everything inside () get evaluated as math
# how to stop Splitter from splittig () way ?
# this would require a rework of the TextCommandStrea
# also at that point it would no longer be TextCommands
# but just complex stuff



varFloat w0 20.00
varFloat w1 32.25

varFloat h0 10.00
varFloat h1 30.00
varFloat h2 42.25

varFloat d0 10.00
varFloat d1 22.25



place truss        -w1 h0 -d1   00 90 00
place truss        -w1 h1 -d1   00 90 00
place truss_cube   -w1 h2 -d1   00 00 00

place truss        +w1 h0 -d1   00 90 00
place truss        +w1 h1 -d1   00 90 00
place truss_cube   +w1 h2 -d1   00 00 00

place truss        -w0 h2 -d1   00 00 90
place truss         00 h2 -d1   00 00 90
place truss        +w0 h2 -d1   00 00 90

place truss        -w1 h2 -d0   00 00 00
place truss        +w1 h2 -d0   00 00 00
place truss        -w1 h2 +d0   00 00 00
place truss        +w1 h2 +d0   00 00 00

place truss        -w1 h0 +d1   00 90 00
place truss        -w1 h1 +d1   00 90 00
place truss_cube   -w1 h2 +d1   00 00 00

place truss        +w1 h0 +d1   00 90 00
place truss        +w1 h1 +d1   00 90 00
place truss_cube   +w1 h2 +d1   00 00 00

place truss        -w0 h2 +d1   00 00 90
place truss         00 h2 +d1   00 00 90
place truss        +w0 h2 +d1   00 00 90



