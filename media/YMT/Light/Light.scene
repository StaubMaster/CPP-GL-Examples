#   }
# }



place Chair   -50 0 -40   00 00 90
place Chair   -50 1 -40   00 00 90
place Chair   -50 2 -40   00 00 90
place Chair   -50 3 -40   00 00 90
place Chair   -50 4 -40   00 00 90
place Chair   -50 5 -40   00 00 90
place Chair   -50 6 -40   00 00 90
place Chair   -50 7 -40   00 00 90
place Chair   -50 8 -40   00 00 90
place Chair   -50 9 -40   00 00 90

place Chair   -50 0 -45   00 00 90
place Chair   -50 1 -45   00 00 90
place Chair   -50 2 -45   00 00 90


